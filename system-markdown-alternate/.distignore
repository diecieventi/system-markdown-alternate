# Files excluded from the WordPress.org package (SVN).
#
# Used by deployment tools (for example 10up/action-wordpress-plugin-deploy)
# that rsync this directory to SVN while excluding these patterns. Note:
# `vendor/` is intentionally omitted because it is a runtime dependency and
# MUST be shipped (bundle it with `composer install --no-dev` before deployment).

/tests
/.distignore
composer.lock

# CLI binaries shipped by league/html-to-markdown. They are never invoked at
# runtime (the plugin uses the library classes only) and the wordpress.org
# Plugin Check flags them as "not permitted files", so keep them out of the
# distributed package while still shipping the rest of vendor/.
vendor/bin
vendor/league/html-to-markdown/bin
