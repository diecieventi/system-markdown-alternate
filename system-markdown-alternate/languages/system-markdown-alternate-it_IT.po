msgid "Markdown Alternate"
msgstr ""

msgid "General"
msgstr "Generale"

msgid "Enabled content types"
msgstr "Tipi di contenuto abilitati"

msgid "Cache TTL (seconds)"
msgstr "Cache TTL (secondi)"

msgid "Markdown output"
msgstr "Output Markdown"

msgid "Excluded shortcodes"
msgstr "Shortcode esclusi"

msgid "Excluded blocks"
msgstr "Blocchi esclusi"

msgid "Excluded CSS classes"
msgstr "Classi CSS escluse"

msgid "ACF subtitle field"
msgstr "Campo ACF sottotitolo"

msgid "ACF TL;DR field"
msgstr "Campo ACF TL;DR"

msgid "ACF fields"
msgstr "Campi ACF"

msgid "Enable /llms.txt"
msgstr "Abilita /llms.txt"

msgid "Integrations"
msgstr "Integrazioni"

msgid "Advanced"
msgstr "Avanzate"

msgid "Main settings. Without at least one selected content type, the plugin stays inactive."
msgstr "Impostazioni principali. Senza almeno un tipo di contenuto selezionato, il plugin resta inattivo."

msgid "Controls what goes into or stays out of the <code>.md</code> file. For exclusions: one entry per line, leave empty to use the built-in defaults."
msgstr "Decide cosa entra o resta fuori dal file <code>.md</code>. Per le esclusioni: una voce per riga, lascia vuoto per usare i default interni."

msgid "Settings for advanced users."
msgstr "Impostazioni per utenti esperti."

msgid "The <code>/llms.txt</code> file exposes selected site resources in a format readable by LLMs and AI agents. It currently lists the enabled Markdown content."
msgstr "Il file <code>/llms.txt</code> espone risorse selezionate del sito in un formato leggibile da LLM e agenti AI. Attualmente elenca i contenuti Markdown abilitati."

msgid "Enabled in the settings:"
msgstr "Abilitato nelle impostazioni:"

msgid "yes"
msgstr "sì"

msgid "no"
msgstr ""

msgid "URL:"
msgstr ""

msgid "Informational section: how to use the <code>.md</code> URL in content and templates."
msgstr "Sezione informativa: come usare l'URL del <code>.md</code> nei contenuti e nei template."

msgid "Shortcode"
msgstr ""

msgid "<code>[sma_md_url]</code> — <code>.md</code> URL of the current post."
msgstr "<code>[sma_md_url]</code> — URL del <code>.md</code> del post corrente."

msgid "<code>[sma_md_url id=\"123\"]</code> — <code>.md</code> URL of a specific post."
msgstr "<code>[sma_md_url id=\"123\"]</code> — URL del <code>.md</code> di un post specifico."

msgid "Returns empty if the post does not expose a .md (type not enabled, draft, or password-protected)."
msgstr "Restituisce vuoto se il post non espone un .md (tipo non abilitato, bozza o protetto da password)."

msgid "GenerateBlocks detected. The dynamic tag is available automatically."
msgstr "GenerateBlocks rilevato. Il dynamic tag è disponibile automaticamente."

msgid "Insert <code>{{sma_md_url}}</code> in GenerateBlocks/GeneratePress fields that accept a dynamic tag, e.g. a button URL. If the post has no <code>.md</code>, the tag resolves to empty and the element is hidden (required to render)."
msgstr "Inserisci <code>{{sma_md_url}}</code> nei campi GenerateBlocks/GeneratePress che accettano un dynamic tag, ad esempio l'URL di un bottone. Se il post non ha un <code>.md</code>, il tag si risolve a vuoto e l'elemento viene nascosto (required to render)."

msgid "GenerateBlocks not detected. The dynamic tag is not available."
msgstr "GenerateBlocks non rilevato. Il dynamic tag non è disponibile."

msgid "ACF detected. The Subtitle and TL;DR fields are configured in the <strong>Markdown output</strong> section."
msgstr "ACF rilevato. I campi Sottotitolo e TL;DR si configurano nella sezione <strong>Output Markdown</strong>."

msgid "ACF not detected. The Subtitle and TL;DR fields are not available."
msgstr "ACF non rilevato. I campi Sottotitolo e TL;DR non sono disponibili."

msgid "A physical <code>llms.txt</code> file exists in the site root: the web server serves it <strong>before</strong> WordPress, so this endpoint (and any other plugin's) is ignored."
msgstr "Esiste un file fisico <code>llms.txt</code> nella root del sito: il web server lo serve <strong>prima</strong> di WordPress, quindi questo endpoint (e quello di altri plugin) viene ignorato."

msgid "Active SEO plugins that <em>might</em> handle <code>/llms.txt</code>: <strong>%s</strong>. If one of them already generates it, keep only one handler active (disable this one below, or the llms.txt feature in the other plugin)."
msgstr "Plugin SEO attivi che <em>potrebbero</em> gestire <code>/llms.txt</code>: <strong>%s</strong>. Se uno di loro lo genera già, tieni attivo un solo gestore (disattiva questo qui sotto, oppure la funzione llms.txt nell'altro plugin)."

msgid "Possible /llms.txt conflict:"
msgstr "Possibile conflitto su /llms.txt:"

msgid "Content types exposed as <code>.md</code> and in <code>/llms.txt</code>. No selection = plugin inactive."
msgstr "Tipi di contenuto esposti come <code>.md</code> e in <code>/llms.txt</code>. Nessuna selezione = plugin inattivo."

msgid "seconds"
msgstr "secondi"

msgid "0 = cache disabled. Default: 86400 (24 hours)."
msgstr "0 = cache disabilitata. Default: 86400 (24 ore)."

msgid "One per line. Leave empty to use the built-in defaults."
msgstr "Uno per riga. Lascia vuoto per usare i default interni."

msgid "Default:"
msgstr ""

msgid "ACF field name for the subtitle (type: text). Inserted in italics right after the H1 title."
msgstr "Nome del campo ACF per il sottotitolo (tipo: testo). Inserito in corsivo subito dopo il titolo H1."

msgid "ACF field name for the TL;DR (type: WYSIWYG editor). Inserted as a <code>**TL;DR**</code> section with <code>---</code> separators."
msgstr "Nome del campo ACF per il TL;DR (tipo: editor WYSIWYG). Inserito come sezione <code>**TL;DR**</code> con separatori <code>---</code>."

msgid "ACF not detected: the Subtitle and TL;DR fields will appear here when ACF is active. Any previously saved settings are preserved."
msgstr "ACF non rilevato: i campi Sottotitolo e TL;DR appariranno qui quando ACF sarà attivo. Le eventuali impostazioni già salvate restano conservate."

msgid "Enable the <code>/llms.txt</code> endpoint"
msgstr "Abilita l'endpoint <code>/llms.txt</code>"

msgid "Disable if another plugin already handles <code>/llms.txt</code>."
msgstr "Disattiva se un altro plugin gestisce già <code>/llms.txt</code>."

msgid "Default: <code>noindex, follow</code>. Leave empty to not send the header."
msgstr "Default: <code>noindex, follow</code>. Lascia vuoto per non inviare l'header."

msgid "System Markdown Alternate: missing dependencies. Run \"composer install\" in the plugin folder, or install the built zip (DIST folder)."
msgstr "System Markdown Alternate: dipendenze mancanti. Esegui \"composer install\" nella cartella del plugin oppure installa lo zip buildato (cartella DIST)."
